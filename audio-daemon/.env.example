# Warehouse Audio Daemon - Environment Configuration
# Copy this file to .env and fill in your values.

# ---------------------------------------------------------------
# Required
# ---------------------------------------------------------------

# Full base URL of your VPS (no trailing slash)
VPS_HOST=http://your-vps-ip:8000

# ---------------------------------------------------------------
# Optional (defaults shown)
# ---------------------------------------------------------------

# WebSocket path on the VPS
WS_PATH=/ws

# How often (seconds) to poll the REST endpoint for pending orders
POLL_INTERVAL=60

# Path to the alert sound file, relative to daemon.py
SOUND_FILE=sounds/nuevo_pedido.mp3

# Optional shared secret sent as X-Daemon-Secret header (leave blank if unused)
DAEMON_SECRET=

# Initial reconnect delay in seconds (doubles on each failure, max 120s)
RECONNECT_DELAY_SECONDS=5
